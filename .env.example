# Пример конфигурации. Скопируйте в .env и отредактируйте под себя.
# .env в git не коммитится (см. .gitignore).

# --- Подключение к БД ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tourist_club
DB_USER=tourist_app
DB_PASSWORD=change_me_please

# Read-only пользователь для SQL-консоли (по умолчанию).
DB_READONLY_USER=tourist_ro
DB_READONLY_PASSWORD=change_me_please_ro

# --- Приложение ---
APP_LOG_LEVEL=INFO
APP_THEME=light

# Пароль встроенного суперадмина при первом запуске seed-скрипта.
APP_DEFAULT_ADMIN_PASSWORD=admin
